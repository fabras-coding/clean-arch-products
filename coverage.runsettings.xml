<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <!-- exclui qualquer pasta chamada Mappings, Mediator ou Mocks em qualquer projeto -->
          <ExcludeByFile>**/Mappings/**,**/Mediator/**,**/Mocks/**</ExcludeByFile>
          <!-- mantém exclusões por assembly/namespace se necessário -->
          <Exclude>[*Tests]*,[*Mock]*</Exclude>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>